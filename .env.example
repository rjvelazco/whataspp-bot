# Which store this bot instance serves (matches a store_id in data/ and the DB)
STORE_ID=novamoda

# Path to the SQLite database file
DB_PATH=./store-bot.sqlite

# Folder where Baileys persists the WhatsApp session credentials
AUTH_DIR=./auth

# Folder where receipt photos are saved
UPLOADS_DIR=./uploads

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# How long (hours) the bot stays quiet for a customer after a human handoff
HANDOFF_PAUSE_HOURS=12

# Pairing method:
#   - Leave PAIR_PHONE empty to pair by scanning a QR code (default).
#   - Set it to the BOT's own WhatsApp number (with country code) to pair with an
#     8-char code instead — more reliable if QR linking fails. Example: +584121234567
#     Then on the phone: Linked Devices → Link a Device → "Link with phone number instead".
PAIR_PHONE=

# Port for the web UI (QR pairing page, and later the payments dashboard)
WEB_PORT=3000
