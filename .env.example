# Which store this bot instance serves (matches a store_id in data/ and the DB)
STORE_ID=novamoda

# Path to the SQLite database file
DB_PATH=./store-bot.sqlite

# Folder where Baileys persists the WhatsApp session credentials
AUTH_DIR=./auth

# Folder where receipt photos are saved
UPLOADS_DIR=./uploads

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# How long (hours) the bot stays quiet for a customer after a human handoff
HANDOFF_PAUSE_HOURS=12
